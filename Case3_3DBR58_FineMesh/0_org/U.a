FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      Ua;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ( 0 0 0 ); 

boundaryField
{
    cylinder
    {
       type            movingWallVelocity;
       value           uniform (0 0 0);
    }
    inlet
    {
        type            codedFixedValue;
        value           uniform (0 0 0);
        
        name    inlet;

        codeInclude
        #{
            #include "fvCFD.H"
        #};

        codeOptions
        #{
            -I$(LIB_SRC)/finiteVolume/lnInclude \
            -I$(LIB_SRC)/meshTools/lnInclude
        #};
        codeLibs
        #{
            -lfiniteVolume \
            -lmeshTools
        #};
        code
        #{
            const fvPatch& boundaryPatch = patch();
            const vectorField& Cf = boundaryPatch.Cf();
            vectorField& field = *this;
            scalar t = this->db().time().value();
            forAll(Cf, faceI)
            {
               if (Cf[faceI].z() >=0.035)
               {
                  if (t <= 16)
                  {   
                     field[faceI] = ((t/16))
                                     *vector
                                      (
                                         0.0378/0.41
                                         *log(30*(Cf[faceI].z())
                                              /5.04e-5),
                                         0,
                                         0
                                       );
                  }
                  else
                  {
                     field[faceI] = vector
                                    (
                                       0.0378/0.41
                                       *log(30*(Cf[faceI].z())
                                            /5.04e-5),
                                       0,
                                       0
                                    );
                  }
               }
               else
               {
                  field[faceI] = vector(0,0,0);
               }
            }
        #};            
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform (0 0 0);
        value           uniform (0 0 0);
    }
    lateralfront
    {
        type            zeroGradient;
    }
    lateralback
    {
        type            zeroGradient;
    }
    bottom
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    surface
    {
        type            zeroGradient;
    }
}


// ************************************************************************* //
